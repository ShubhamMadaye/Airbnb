<%- include('../partials/head') %>
    </head>

    <body class="bg-[var(--background)] text-[var(--text)] font-sans min-h-screen flex flex-col">
 
         <%- include('../partials/nav') %>
 
             <main class="flex-1 w-full max-w-md mx-auto px-6 py-12 flex flex-col justify-center">
 
                 <header class="mb-8 text-center">
                     <h1 class="text-4xl font-bold tracking-tight mb-2 text-[var(--text)]">Create Account</h1>
                     <p class="text-[var(--text-muted)] text-sm">Join StayNest — book a stay or list your home.</p>
                 </header>
 
                 <% if (error) { %>
                     <div
                         class="bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded-xl mb-6 text-sm text-center">
                         <%= error %>
                     </div>
                     <% } %>
 
                         <div class="bg-white border border-gray-200 rounded-2xl shadow-md p-8">
                             <form action="/auth/register" method="POST" class="flex flex-col gap-5" id="register-form">
 
                                 <!-- Role Picker -->
                                 <div class="flex flex-col gap-2 text-left">
                                     <label class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-widest">I want
                                         to join as</label>
                                     <div class="grid grid-cols-2 gap-3">
 
                                         <!-- Guest card -->
                                         <label for="role-guest" id="card-guest"
                                             class="role-card cursor-pointer flex flex-col items-center gap-2 p-4 rounded-xl border-2 transition-all duration-200 selected"
                                             onclick="selectRole('guest')">
                                             <input type="radio" id="role-guest" name="isHost" value="false"
                                                 class="hidden" checked />
                                             <span class="text-3xl">🧳</span>
                                             <span class="font-bold text-sm text-[var(--text)]">Guest</span>
                                             <span class="text-[var(--text-muted)] text-[11px] text-center leading-tight">Browse
                                                 &amp; book stays</span>
                                         </label>
 
                                         <!-- Host card -->
                                         <label for="role-host" id="card-host"
                                             class="role-card cursor-pointer flex flex-col items-center gap-2 p-4 rounded-xl border-2 transition-all duration-200"
                                             onclick="selectRole('host')">
                                             <input type="radio" id="role-host" name="isHost" value="true"
                                                 class="hidden" />
                                             <span class="text-3xl">🏡</span>
                                             <span class="font-bold text-sm text-[var(--text)]">Host</span>
                                             <span class="text-[var(--text-muted)] text-[11px] text-center leading-tight">List
                                                 &amp; rent your home</span>
                                         </label>
                                     </div>
                                 </div>
 
                                 <div class="flex flex-col gap-1 text-left">
                                     <label class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-widest">Full
                                         Name</label>
                                     <input
                                         class="bg-white text-gray-800 placeholder-gray-400 border border-gray-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-rose-400 transition w-full"
                                         type="text" name="name" placeholder="John Doe" required />
                                 </div>
 
                                 <div class="flex flex-col gap-1 text-left">
                                     <label
                                         class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-widest">Email</label>
                                     <input
                                         class="bg-white text-gray-800 placeholder-gray-400 border border-gray-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-rose-400 transition w-full"
                                         type="email" name="email" placeholder="you@example.com" required />
                                 </div>
 
                                 <div class="flex flex-col gap-1 text-left">
                                     <label
                                         class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-widest">Password</label>
                                     <input
                                         class="bg-white text-gray-800 placeholder-gray-400 border border-gray-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-rose-400 transition w-full"
                                         type="password" name="password" placeholder="••••••••" required minlength="6" />
                                 </div>
 
                                 <button type="submit"
                                     class="mt-2 bg-[var(--primary)] hover:bg-[var(--primary-hover)] text-white font-bold py-3 px-6 rounded-xl shadow-md hover:scale-105 transform transition duration-300">
                                     Create Account
                                 </button>
 
                             </form>
 
                             <p class="mt-6 text-center text-sm text-[var(--text-muted)]">
                                 Already have an account?
                                 <a href="/auth/login" class="text-[var(--primary)] hover:text-[var(--primary-hover)] hover:underline font-semibold">Log in</a>
                             </p>
                         </div>

            </main>

            <style>
                .role-card {
                    border: 2px solid #E5E7EB !important;
                    background-color: #FFFFFF !important;
                    transition: all 0.2s ease !important;
                }

                .role-card:hover {
                    border-color: #D1D5DB !important;
                    background-color: #F9FAFB !important;
                }

                .role-card.selected {
                    border-color: #F43F5E !important;
                    background-color: rgba(244, 63, 94, 0.08) !important;
                    border-width: 2px !important;
                }
            </style>

            <script>
                function selectRole(role) {
                    document.querySelectorAll('.role-card').forEach(c => c.classList.remove('selected'));
                    document.getElementById('card-' + role).classList.add('selected');
                    document.getElementById('role-' + role).checked = true;
                }
            </script>

    </body>

    </html>