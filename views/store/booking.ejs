<%- include('../partials/head') %>
</head>

<body class="bg-[var(--background)] text-[var(--text)] font-sans min-h-screen flex flex-col">
 
     <%- include('../partials/nav') %>
 
     <main class="flex-1 w-full max-w-lg mx-auto px-6 py-16">
 
         <a href="/listings/<%= id %>"
             class="inline-flex items-center gap-2 text-[var(--text-light)] hover:text-[var(--text)] text-sm mb-8 transition uppercase tracking-wider font-bold">
             <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[var(--accent)]" fill="none" viewBox="0 0 24 24"
                 stroke="currentColor" stroke-width="2.5">
                 <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
             </svg>
             Back to Property
         </a>
 
         <header class="mb-10 border-b border-gray-200 pb-6 text-left">
             <h1 class="text-4xl font-extrabold text-[var(--text)] mb-2">Book Reservation</h1>
             <p class="text-[var(--text-light)] text-xs uppercase tracking-wider font-semibold capitalize mb-1"><%= home.housename %> · <%= home.location %></p>
             <p class="text-[var(--text-muted)] text-xs">Rate: <strong class="text-[var(--accent)] text-sm">₹<%= Number(home.pricePerNight).toLocaleString('en-IN') %></strong> / night</p>
         </header>
 
         <% if (error) { %>
             <div class="bg-red-500/10 border border-red-500/20 text-red-600 rounded-xl px-4 py-3 mb-6 text-sm flex items-center gap-2">
                 <span>⚠️</span> <%= error %>
             </div>
         <% } %>
 
         <div class="bg-white border border-gray-200 rounded-3xl p-8 shadow-md">
             <form action="/book/<%= id %>" method="POST" class="flex flex-col gap-6">
 
                 <!-- Check-in -->
                 <div class="flex flex-col gap-1.5 text-left">
                     <label class="text-xs font-bold uppercase tracking-wider text-[var(--text-light)]">Check-in Date</label>
                     <input
                         class="bg-white border border-gray-200 rounded-xl px-4 py-3 text-gray-800 placeholder-gray-400 focus:outline-none focus:border-rose-500 transition w-full"
                         type="date"
                         name="checkIn"
                         min="<%= new Date().toISOString().split('T')[0] %>"
                         required />
                 </div>
 
                 <!-- Check-out -->
                 <div class="flex flex-col gap-1.5 text-left">
                     <label class="text-xs font-bold uppercase tracking-wider text-[var(--text-light)]">Check-out Date</label>
                     <input
                         class="bg-white border border-gray-200 rounded-xl px-4 py-3 text-gray-800 placeholder-gray-400 focus:outline-none focus:border-rose-500 transition w-full"
                         type="date"
                         name="checkOut"
                         min="<%= new Date().toISOString().split('T')[0] %>"
                         required />
                 </div>
 
                 <!-- Cost preview (computed client-side) -->
                 <div id="costPreview" class="hidden bg-rose-50 border border-rose-200 text-[var(--primary)] rounded-xl px-5 py-3.5 text-sm font-semibold flex items-center gap-2"></div>
 
                 <!-- Submit -->
                 <button type="submit"
                     class="w-full bg-[var(--primary)] hover:bg-[var(--primary-hover)] text-white font-bold py-3.5 px-6 rounded-xl shadow-lg transform hover:scale-102 transition duration-300 uppercase text-xs tracking-wider mt-2">
                     Confirm Booking
                 </button>
             </form>
         </div>

    </main>

    <script>
        var pricePerNight = Number('<%= home.pricePerNight %>');
        var checkInInput = document.querySelector('[name="checkIn"]');
        var checkOutInput = document.querySelector('[name="checkOut"]');
        var preview = document.getElementById('costPreview');

        function updatePreview() {
            var a = new Date(checkInInput.value);
            var b = new Date(checkOutInput.value);
            if (checkInInput.value && checkOutInput.value && b > a) {
                var nights = Math.ceil((b - a) / (1000 * 60 * 60 * 24));
                var total = nights * pricePerNight;
                var label = nights > 1 ? 'nights' : 'night';
                preview.textContent = '🌙 ' + nights + ' ' + label + ' · Total: ₹' + total.toLocaleString('en-IN');
                preview.classList.remove('hidden');
            } else {
                preview.classList.add('hidden');
            }
        }

        checkInInput.addEventListener('change', updatePreview);
        checkOutInput.addEventListener('change', updatePreview);
    </script>

</body>
</html>