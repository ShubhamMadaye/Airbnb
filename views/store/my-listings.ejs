<%- include('../partials/head') %>
    </head>

    <body class="bg-[var(--background)] text-[var(--text)] font-sans min-h-screen flex flex-col">
 
         <%- include('../partials/nav') %>
 
             <main class="flex-1 w-full max-w-5xl mx-auto px-6 py-12">
 
                 <header class="flex items-center justify-between mb-8 flex-wrap gap-4 text-left">
                     <div>
                         <h1 class="text-3xl font-bold text-[var(--text)]">🏠 My Listings</h1>
                         <p class="text-[var(--text-muted)] mt-1 text-sm font-medium">
                             Homes you've listed on AirBnB &nbsp;·&nbsp; <%= listings.length %> listing<%=
                                     listings.length !==1 ? 's' : '' %>
                         </p>
                     </div>
                     <a href="/list-home"
                         class="bg-[var(--primary)] hover:bg-[var(--primary-hover)] text-white font-bold py-3 px-6 rounded-full shadow-md hover:scale-105 transform transition duration-300 text-sm">
                         + List Another Home
                     </a>
                 </header>
 
                 <!-- Success Banner -->
                 <% if (success) { %>
                     <div
                         class="bg-green-100 border border-green-200 text-green-800 rounded-xl px-5 py-4 mb-6 flex items-center gap-3">
                         <span class="text-2xl">🎉</span>
                         <div>
                             <p class="font-semibold">Your home is now live!</p>
                             <p class="text-sm text-green-600">Travellers can now discover and book your property.</p>
                         </div>
                     </div>
                     <% } %>
 
                         <% if (listings.length===0) { %>
                             <div class="bg-white border border-gray-200 rounded-2xl p-12 text-center shadow-md">
                                 <div class="text-6xl mb-4">🏡</div>
                                 <h2 class="text-xl font-semibold text-[var(--text)]">You haven't listed any homes yet</h2>
                                 <p class="text-[var(--text-muted)] text-sm mt-2 font-medium">Share your property with travellers from around
                                     the world!</p>
                                 <a href="/list-home"
                                     class="inline-block mt-6 bg-[var(--primary)] hover:bg-[var(--primary-hover)] text-white font-bold py-3 px-8 rounded-full shadow-md hover:scale-105 transform transition duration-300">
                                     + List Your First Home
                                 </a>
                             </div>
                             <% } else { %>
                                 <div class="flex flex-col gap-4">
                                     <% listings.forEach(({ home, index })=> {
                                         var count = bookingCounts[index] || 0;
                                         %>
                                         <div
                                             class="bg-white border border-gray-200 rounded-2xl p-5 flex items-center gap-5 shadow-md hover:border-gray-300 transition">
 
                                             <!-- Photo -->
                                             <div
                                                 class="w-20 h-20 rounded-xl overflow-hidden flex-shrink-0 bg-gray-100">
                                                 <% if (home.photo) { %>
                                                     <img src="<%= home.photo %>" alt="<%= home.housename %>"
                                                         class="w-full h-full object-cover"
                                                         onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
                                                     <div
                                                         class="w-full h-full hidden items-center justify-center text-gray-300 text-4xl">
                                                         🏡</div>
                                                     <% } else { %>
                                                         <div
                                                             class="w-full h-full flex items-center justify-center text-gray-300 text-4xl">
                                                             🏡</div>
                                                         <% } %>
                                             </div>
 
                                             <!-- Info -->
                                             <div class="flex-1 min-w-0 text-left">
                                                 <div class="flex items-center gap-3 flex-wrap">
                                                     <h2 class="text-lg font-bold text-[var(--text)] capitalize truncate">
                                                         <%= home.housename %>
                                                     </h2>
                                                     <% if (count> 0) { %>
                                                         <span
                                                             class="inline-flex items-center gap-1 bg-green-100 border border-green-200 text-green-700 text-xs font-semibold px-2 py-0.5 rounded-full">
                                                             ✅ <%= count %> booking<%= count> 1 ? 's' : '' %>
                                                         </span>
                                                         <% } else { %>
                                                             <span
                                                                 class="inline-flex items-center gap-1 bg-gray-100 border border-gray-200 text-gray-500 text-xs font-semibold px-2 py-0.5 rounded-full">
                                                                 Awaiting bookings
                                                             </span>
                                                             <% } %>
                                                 </div>
                                                 <p class="text-[var(--text-muted)] text-sm capitalize flex items-center gap-1 font-semibold mt-0.5">
                                                     <svg class="map-pin-svg text-[var(--accent)]" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                                                     <%= home.location %>
                                                 </p>
                                                 <p class="text-[var(--text-light)]/80 text-sm mt-0.5">₹<%=
                                                         Number(home.pricePerNight).toLocaleString('en-IN') %> / night
                                                         &nbsp;·&nbsp; Listing #<%= index + 1 %>
                                                 </p>
                                             </div>
 
                                             <!-- Actions -->
                                             <div class="flex items-center gap-3 flex-shrink-0">
                                                 <a href="/listings/<%= index %>"
                                                     class="bg-white border border-gray-200 hover:border-gray-400 text-gray-700 font-semibold py-2 px-4 rounded-xl text-sm transition shadow-sm"
                                                     title="View public listing">
                                                     👁 View
                                                 </a>
                                             </div>
 
                                         </div>
                                         <% }) %>
                                 </div>
                                 <% } %>

            </main>

    </body>

    </html>