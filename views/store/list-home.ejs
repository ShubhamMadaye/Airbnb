<%- include('../partials/head') %>
    </head>

    <body class="bg-[var(--background)] text-[var(--text)] font-sans min-h-screen flex flex-col">
 
         <%- include('../partials/nav') %>
 
             <main class="flex-1 w-full max-w-lg mx-auto px-6 py-12">
 
                 <a href="/"
                     class="inline-flex items-center gap-2 text-[var(--text-light)] hover:text-[var(--text)] text-sm mb-8 transition">
                     <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24"
                         stroke="currentColor" stroke-width="2">
                         <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
                     </svg>
                     Back to Listings
                 </a>
 
                 <header class="mb-8 text-left">
                     <h1 class="text-3xl font-bold text-[var(--text)]">🏡 List Your Home</h1>
                     <p class="text-[var(--text-muted)] mt-1 text-sm">Fill in the details and your property will go live instantly</p>
                 </header>
 
                 <% if (error) { %>
                     <div class="bg-red-50 border border-red-200 text-red-600 rounded-xl px-4 py-3 mb-6 text-sm text-left">
                         ⚠️ <%= error %>
                     </div>
                     <% } %>
 
                         <div class="bg-white border border-gray-200 rounded-2xl shadow-md p-8">
                             <form action="/list-home" method="POST" class="flex flex-col gap-5"
                                 enctype="multipart/form-data">
 
                                 <!-- Home Name -->
                                 <div class="flex flex-col gap-1 text-left">
                                     <label
                                         class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-widest">Property
                                         Name</label>
                                     <input
                                         class="bg-white text-gray-800 placeholder-gray-400 border border-gray-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-rose-400 transition w-full"
                                         type="text" name="homeName" placeholder="e.g. Cozy Beach Cottage" required />
                                 </div>
 
                                 <!-- Location -->
                                 <div class="flex flex-col gap-1 text-left">
                                     <label
                                         class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-widest">Location</label>
                                     <input
                                         class="bg-white text-gray-800 placeholder-gray-400 border border-gray-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-rose-400 transition w-full"
                                         type="text" name="houseAddress" placeholder="e.g. Goa, India" required />
                                 </div>
 
                                 <!-- Price Per Night -->
                                 <div class="flex flex-col gap-1 text-left">
                                     <label class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-widest">Price
                                         Per Night (₹)</label>
                                     <input
                                         class="bg-white text-gray-800 placeholder-gray-400 border border-gray-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-rose-400 transition w-full"
                                         type="number" name="pricePerNight" placeholder="e.g. 4500" min="1" required />
                                 </div>
 
                                 <!-- Photo image -->
                                 <div class="flex flex-col gap-1 text-left">
                                     <label
                                         class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-widest">Photo<span
                                             class="text-gray-400 normal-case font-normal"> (optional)</span></label>
                                     <input
                                         class="bg-white text-gray-800 placeholder-gray-400 border border-gray-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-rose-400 transition w-full"
                                         type="file" name="photo" accept="image/*" />
                                 </div>
 
                                 <!-- Hosted by badge -->
                                 <div
                                     class="bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 flex items-center gap-3 text-sm">
                                     <span class="text-2xl">👤</span>
                                     <div class="text-left">
                                         <p class="font-semibold text-[var(--text)]">Listed by <strong>
                                                 <%= user.name %>
                                             </strong></p>
                                         <p class="text-[var(--text-light)]/80 text-xs">Your name will appear on the listing</p>
                                     </div>
                                 </div>
 
                                 <!-- Submit -->
                                 <button type="submit"
                                     class="w-full bg-[var(--primary)] hover:bg-[var(--primary-hover)] text-white font-bold py-3 px-6 rounded-xl shadow-md hover:scale-105 transform transition duration-300">
                                     🚀 Publish Listing
                                 </button>
                             </form>
                         </div>

            </main>

    </body>

    </html>