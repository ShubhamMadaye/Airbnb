<%- include('../partials/head') %>
</head>

<body class="bg-[var(--background)] text-[var(--text)] font-sans min-h-screen flex flex-col">

    <%- include('../partials/nav') %>

    <!-- Premium Option 1 Hero Section -->
    <section class="widescreen-container pt-12 pb-6 grid grid-cols-1 lg:grid-cols-12 gap-8 items-center">
        <!-- Left Info Column -->
        <div class="lg:col-span-7 flex flex-col text-left">
            <h1 class="text-5xl lg:text-6xl font-extrabold tracking-tight leading-tight text-[var(--text)] mb-4">
                Find your <br>
                <span class="text-[var(--accent)]">perfect stay</span>
            </h1>
            <p class="text-[var(--text-light)] text-lg max-w-lg mb-8 leading-relaxed">
                Discover unique places to stay with local hosts all over the world.
            </p>

            <!-- Modern Search Bar Nested Left -->
            <div class="search-bar-luxury rounded-full p-2 pl-6 flex items-center justify-between gap-4 w-full max-w-xl transition">
                <div class="flex-1 text-left min-w-0">
                    <label for="search-where"
                        class="block text-[10px] font-extrabold text-[var(--text-light)] uppercase tracking-wider cursor-pointer select-none">Where</label>
                    <input type="text" id="search-where" placeholder="Search destinations..."
                        class="search-input-clean text-xs font-semibold text-[var(--text)] placeholder-slate-400 focus:outline-none"
                        style="border: none !important; box-shadow: none !important; padding: 0 !important; background: transparent !important; color: var(--text) !important; width: 100% !important; margin-top: 1px;" />
                </div>
                <div class="w-px h-8 bg-gray-200"></div>
                <div class="flex-1 text-left hidden sm:block">
                    <label for="search-checkin"
                        class="block text-[10px] font-extrabold text-[var(--text-light)] uppercase tracking-wider cursor-pointer select-none">Check in</label>
                    <input type="date" id="search-checkin"
                        class="search-input-clean text-xs font-semibold text-[var(--text-light)]"
                        style="border: none !important; box-shadow: none !important; padding: 0 !important; background: transparent !important; color: var(--text-light) !important; width: 100% !important; margin-top: 1px;" />
                </div>
                <div class="w-px h-8 bg-gray-200 hidden sm:block"></div>
                <div class="flex-1 text-left hidden sm:block">
                    <label for="search-guests"
                        class="block text-[10px] font-extrabold text-[var(--text-light)] uppercase tracking-wider cursor-pointer select-none">Who</label>
                    <select id="search-guests"
                        class="search-input-clean text-xs font-semibold text-[var(--text-light)] cursor-pointer"
                        style="border: none !important; box-shadow: none !important; padding: 0 !important; background: transparent !important; color: var(--text-light) !important; width: 100% !important; margin-top: 1px;">
                        <option value="" class="bg-white text-[var(--text)]">Add guests</option>
                        <option value="1" class="bg-white text-[var(--text)]">1 guest</option>
                        <option value="2" class="bg-white text-[var(--text)]">2 guests</option>
                        <option value="3" class="bg-white text-[var(--text)]">3 guests</option>
                        <option value="4" class="bg-white text-[var(--text)]">4+ guests</option>
                    </select>
                </div>
                <button id="search-submit-btn"
                    class="bg-[var(--primary)] hover:bg-[var(--primary-hover)] text-white rounded-full px-6 py-3 font-bold text-xs transition shadow-md flex items-center justify-center flex-shrink-0 cursor-pointer">
                    Search
                </button>
            </div>
        </div>

        <!-- Right Image Column (beachfront villa generated image) -->
        <div class="lg:col-span-5 hidden lg:block">
            <div class="w-full h-[380px] rounded-3xl overflow-hidden bg-gray-100 relative group select-none">
                <img src="/hero-bg.png" alt="StayNest Beachfront Room"
                    class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/10 to-transparent"></div>
            </div>
        </div>
    </section>

    <!-- Categories Scrollable Bar -->
    <section class="widescreen-container mb-12 mt-6">
        <div class="flex items-center justify-start md:justify-center gap-8 overflow-x-auto pb-4 scrollbar-none">
            <button class="category-btn active" data-category="all">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                <span>All stays</span>
            </button>
            <button class="category-btn" data-category="beachfront">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M2 20a5 5 0 0 1 8 0 5 5 0 0 1 8 0 5 5 0 0 1 4 0"/><path d="M12 10a4 4 0 1 0 0-8 4 4 0 0 0 0 8z"/><path d="M12 2v2"/><path d="M12 8v2"/><path d="M6 12l2 2"/><path d="M18 12l-2 2"/></svg>
                <span>Beachfront</span>
            </button>
            <button class="category-btn" data-category="cabins">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="12 2 3 17 9 17 5 21 19 21 15 17 21 17 12 2"/></svg>
                <span>Cabins</span>
            </button>
            <button class="category-btn" data-category="mansions">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18"/><path d="M2 22h20"/><path d="M12 18v4"/><path d="M10 6h4"/><path d="M10 10h4"/><path d="M10 14h4"/></svg>
                <span>Mansions</span>
            </button>
            <button class="category-btn" data-category="camping">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M2 21L12 3l10 18H2z"/><path d="M12 3v18"/></svg>
                <span>Camping</span>
            </button>
            <button class="category-btn" data-category="lakefront">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M2 6c.6.5 1.2 1 2.5 1s2.5-.5 3.1-1c.6-.5 1.2-1 2.5-1s2.5.5 3.1 1c.6.5 1.2 1 2.5 1s2.5-.5 3.1-1M2 12c.6.5 1.2 1 2.5 1s2.5-.5 3.1-1c.6-.5 1.2-1 2.5-1s2.5.5 3.1 1c.6.5 1.2 1 2.5 1s2.5-.5 3.1-1M2 18c.6.5 1.2 1 2.5 1s2.5-.5 3.1-1c.6-.5 1.2-1 2.5-1s2.5.5 3.1 1c.6.5 1.2 1 2.5 1s2.5-.5 3.1-1"/></svg>
                <span>Lakefront</span>
            </button>
        </div>
    </section>

    <!-- Main Listings Content -->
    <main class="flex-1 w-full widescreen-container pb-16">
 
        <% if (homes.length === 0) { %>
            <div class="luxury-card p-16 text-center max-w-lg mx-auto mt-8">
                <span class="text-6xl mb-4 select-none">🏡</span>
                <h2 class="text-2xl font-bold text-[var(--text)] mb-2">No homes listed yet</h2>
                <p class="text-[var(--text-light)] text-sm mb-6">Be the first host to list a home on StayNest.</p>
                <a href="/list-home"
                    class="inline-block bg-[var(--primary)] hover:bg-[var(--primary-hover)] text-white font-bold py-2.5 px-8 rounded-full shadow-lg transform hover:scale-102 transition">
                    List Your Home
                </a>
            </div>
        <% } else { %>
 
            <!-- Subsection Header: Explore stays nearby -->
            <div class="flex items-center justify-between mb-8 pb-3">
                <h2 class="text-2xl font-extrabold text-[var(--text)] tracking-tight">Explore stays nearby</h2>
                <a href="/" class="text-[var(--accent)] hover:text-[var(--primary-hover)] font-bold text-xs uppercase tracking-wider transition">View all</a>
            </div>
 
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
                <% homes.forEach((home) => { %>
                    <article id="home-card-<%= home.id %>"
                        class="luxury-card flex flex-col group relative home-card"
                        data-title="<%= home.housename %>" data-location="<%= home.location %>">
 
                        <!-- Image Viewport -->
                        <div class="w-full h-48 bg-gray-100 overflow-hidden relative select-none">
                            <% if (user && home.ownerId && String(home.ownerId) === String(user.id)) { %>
                                <span class="absolute top-4 left-4 bg-[var(--accent)] text-white text-[9px] font-extrabold uppercase tracking-wider px-2.5 py-1 rounded-full shadow-md z-10 flex items-center gap-1 border border-white/10">
                                    🏠 My Listing
                                </span>
                            <% } %>
 
                            <!-- Floating Heart Favorite Button -->
                            <form action="/listings/<%= home.id %>/favourite" method="POST" class="absolute top-4 right-4 z-10">
                                <button type="submit" title="Toggle Favourite"
                                    class="w-9 h-9 rounded-full bg-white border border-gray-200 flex items-center justify-center shadow-md hover:scale-110 active:scale-95 hover:bg-gray-50 transition text-sm leading-none cursor-pointer">
                                    <%= favs.includes(home.id) ? '❤️' : '🤍' %>
                                </button>
                            </form>
 
                            <% if (home.photo) { %>
                                <img src="<%= home.photo %>" alt="<%= home.housename %>"
                                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                                    onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
                                <div class="absolute inset-0 hidden flex-col items-center justify-center text-gray-300 text-5xl">🏡</div>
                            <% } else { %>
                                <div class="w-full h-full flex flex-col items-center justify-center text-gray-300 text-5xl">🏡</div>
                            <% } %>
                        </div>
 
                        <!-- Card Body Info -->
                        <div class="p-5 flex flex-col gap-2 flex-1 text-left">
                            <!-- Title -->
                            <h3 class="text-base font-bold text-[var(--text)] capitalize truncate leading-snug">
                                <%= home.housename %>
                            </h3>
 
                            <!-- Star Rating -->
                            <div class="flex items-center gap-1 text-yellow-400 text-xs">
                                <% const r = ratings[String(home.id)] || 0; %>
                                <span>★</span>
                                <span class="text-[var(--text-light)] text-xs font-semibold">
                                    <%= r > 0 ? r.toFixed(1) : 'New' %>
                                </span>
                            </div>
 
                            <!-- Location -->
                            <p class="text-xs text-[var(--text-light)] capitalize truncate font-medium flex items-center gap-1 mb-2">
                                <svg class="map-pin-svg text-[var(--accent)]" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                                <%= home.location || 'Location not specified' %>
                            </p>
 
                            <!-- Bottom Row: Price & Details -->
                            <div class="mt-auto pt-4 flex items-center justify-between">
                                <div class="flex items-baseline">
                                    <span class="text-lg font-extrabold text-[var(--text)]">
                                        ₹<%= Number(home.pricePerNight).toLocaleString('en-IN') %>
                                    </span>
                                    <span class="text-[var(--text-light)] text-[10px] ml-0.5">/ night</span>
                                </div>
                                <a href="/listings/<%= home.id %>"
                                    class="bg-white border border-gray-200 hover:border-gray-400 text-gray-800 font-bold py-1.5 px-3.5 rounded-lg text-[10px] uppercase tracking-wider transition duration-300">
                                    Details
                                </a>
                            </div>
                        </div>
                    </article>
                <% }) %>
            </div>

            <!-- Empty state for categories -->
            <div id="no-category-results" class="hidden flex-col items-center justify-center py-24 text-center max-w-lg mx-auto mt-8 luxury-card p-12">
                <span class="text-6xl mb-4 select-none">🔍</span>
                <h2 class="text-2xl font-bold text-white mb-2">No stays in this category</h2>
                <p class="text-[var(--text-light)] text-sm mb-6">We couldn't find any listings matching this category. Try another filter!</p>
                <button onclick="document.querySelector('[data-category=\'all\']').click()"
                    class="bg-white hover:bg-gray-100 text-black font-bold py-2.5 px-8 rounded-full shadow-lg transform hover:scale-102 transition cursor-pointer">
                    View All Stays
                </button>
            </div>

        <% } %>
    </main>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const categoryButtons = document.querySelectorAll('[data-category]');
            const cards = document.querySelectorAll('.home-card');
            const noResults = document.getElementById('no-category-results');

            function getCategories(title, location) {
                const t = (title || '').toLowerCase();
                const l = (location || '').toLowerCase();
                const cats = ['all'];

                if (t.includes('beach') || t.includes('sea') || t.includes('coast') || l.includes('goa') || l.includes('malvan') || l.includes('beach') || l.includes('mumbai')) {
                    cats.push('beachfront');
                }
                if (t.includes('cabin') || t.includes('cottage') || t.includes('wood') || t.includes('cozy') || t.includes('forest') || t.includes('crup') || t.includes('krup')) {
                    cats.push('cabins');
                }
                if (t.includes('mansion') || t.includes('palace') || t.includes('nivas') || t.includes('krupa') || t.includes('villa') || t.includes('sai') || t.includes('sri')) {
                    cats.push('mansions');
                }
                if (t.includes('camp') || t.includes('tent') || t.includes('nature') || t.includes('outdoor')) {
                    cats.push('camping');
                }
                if (t.includes('lake') || t.includes('pool') || t.includes('river') || t.includes('water') || l.includes('goa') || l.includes('malvan')) {
                    cats.push('lakefront');
                }

                // Fallback
                if (cats.length === 1) {
                    cats.push('cabins');
                }

                return cats;
            }

            let activeCategory = 'all';
            let activeSearchQuery = '';

            function filterListings() {
                let visibleCount = 0;
                cards.forEach(card => {
                    const title = card.getAttribute('data-title').toLowerCase();
                    const location = card.getAttribute('data-location').toLowerCase();
                    const categories = getCategories(title, location);

                    const categoryMatches = (activeCategory === 'all' || categories.includes(activeCategory));
                    const searchMatches = (!activeSearchQuery || title.includes(activeSearchQuery) || location.includes(activeSearchQuery));

                    if (categoryMatches && searchMatches) {
                        card.style.display = 'flex';
                        setTimeout(() => {
                            card.style.opacity = '1';
                            card.style.transform = 'scale(1)';
                            card.style.pointerEvents = 'auto';
                        }, 10);
                        visibleCount++;
                    } else {
                        card.style.opacity = '0';
                        card.style.transform = 'scale(0.95)';
                        card.style.pointerEvents = 'none';
                        setTimeout(() => {
                            card.style.display = 'none';
                        }, 200);
                    }
                });

                if (visibleCount === 0) {
                    noResults.classList.remove('hidden');
                    noResults.classList.add('flex');
                } else {
                    noResults.classList.add('hidden');
                    noResults.classList.remove('flex');
                }
            }

            categoryButtons.forEach(btn => {
                btn.addEventListener('click', () => {
                    activeCategory = btn.getAttribute('data-category');
                    categoryButtons.forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    filterListings();
                });
            });

            const searchWhere = document.getElementById('search-where');
            const searchSubmitBtn = document.getElementById('search-submit-btn');

            function triggerSearch() {
                activeSearchQuery = searchWhere.value.trim().toLowerCase();
                filterListings();
            }

            searchSubmitBtn.addEventListener('click', triggerSearch);
            searchWhere.addEventListener('keyup', (e) => {
                if (e.key === 'Enter') {
                    triggerSearch();
                }
            });
        });
    </script>

</body>
</html>