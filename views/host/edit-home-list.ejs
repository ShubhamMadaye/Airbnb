<%- include('../partials/head') %>
</head>

<body class="bg-gradient-to-br from-amber-600 to-amber-800 text-white font-sans min-h-screen flex flex-col"
    style="font-family: 'Inter', sans-serif;">

    <%- include('../partials/nav') %>

    <main class="flex-1 w-full max-w-5xl mx-auto px-6 py-12">

        <header class="flex items-center justify-between mb-8 flex-wrap gap-4">
            <div>
                <h1 class="text-3xl font-bold">🏠 Manage Listings</h1>
                <p class="text-amber-200 mt-1 text-sm">
                    <%= homes ? homes.length : 0 %> listings &nbsp;·&nbsp;
                    <%= Object.values(bookingCounts).reduce((s, n) => s + n, 0) %> total bookings
                </p>
            </div>
            <div class="flex gap-3">
                <a href="/host/bookings"
                    class="bg-white/10 border border-white/20 hover:bg-white/20 text-white font-semibold py-3 px-5 rounded-full transition text-sm">
                    📋 All Bookings
                </a>
                <a href="/host/add-home"
                    class="bg-gradient-to-r from-amber-400 to-amber-500 hover:from-amber-500 hover:to-amber-600 text-white font-bold py-3 px-6 rounded-full shadow-lg hover:shadow-xl hover:scale-105 transform transition duration-300">
                    + Add New Home
                </a>
            </div>
        </header>

        <% if (!homes || homes.length === 0) { %>
            <div class="bg-white/10 border border-white/10 rounded-2xl p-12 text-center">
                <div class="text-6xl mb-4">📭</div>
                <h2 class="text-xl font-semibold">No listings yet</h2>
                <p class="text-amber-200 text-sm mt-2">Add your first home to get started.</p>
                <a href="/host/add-home"
                    class="inline-block mt-6 bg-gradient-to-r from-amber-400 to-amber-500 hover:from-amber-500 hover:to-amber-600 text-white font-bold py-3 px-8 rounded-full shadow-lg hover:scale-105 transform transition duration-300">
                    + Add Home
                </a>
            </div>
        <% } else { %>
            <div class="flex flex-col gap-4">
                <% homes.forEach((home) => {
                    var count = bookingCounts[home.id] || 0;
                %>
                    <div class="bg-white/10 backdrop-blur-md border border-white/10 rounded-2xl p-5 flex items-center gap-5 shadow-xl hover:bg-white/15 transition">

                        <!-- Photo Thumbnail -->
                        <div class="w-20 h-20 rounded-xl overflow-hidden flex-shrink-0 bg-amber-900/40">
                            <% if (home.photo) { %>
                                <img src="<%= home.photo %>" alt="<%= home.housename %>"
                                    class="w-full h-full object-cover"
                                    onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
                                <div class="w-full h-full hidden items-center justify-center text-4xl">🏡</div>
                            <% } else { %>
                                <div class="w-full h-full flex items-center justify-center text-4xl">🏡</div>
                            <% } %>
                        </div>

                        <!-- Home Info -->
                        <div class="flex-1 min-w-0">
                            <div class="flex items-center gap-3 flex-wrap">
                                <h2 class="text-lg font-bold capitalize truncate"><%= home.housename %></h2>
                                <!-- Status badge -->
                                <% if (home.status === 'pending') { %>
                                    <span class="inline-flex items-center gap-1 bg-yellow-500/20 border border-yellow-400/40 text-yellow-300 text-xs font-semibold px-2 py-0.5 rounded-full">
                                        ⏳ Pending Approval
                                    </span>
                                <% } else if (home.status === 'rejected') { %>
                                    <span class="inline-flex items-center gap-1 bg-red-500/20 border border-red-400/40 text-red-300 text-xs font-semibold px-2 py-0.5 rounded-full">
                                        ❌ Rejected
                                    </span>
                                <% } else { %>
                                    <span class="inline-flex items-center gap-1 bg-green-500/20 border border-green-400/40 text-green-300 text-xs font-semibold px-2 py-0.5 rounded-full">
                                        ✓ Approved
                                    </span>
                                <% } %>
                                <!-- Booking count badge -->
                                <% if (count > 0) { %>
                                    <span class="inline-flex items-center gap-1 bg-green-500/20 border border-green-400/40 text-green-300 text-xs font-semibold px-2 py-0.5 rounded-full">
                                        ✅ <%= count %> booking<%= count > 1 ? 's' : '' %>
                                    </span>
                                <% } else { %>
                                    <span class="inline-flex items-center gap-1 bg-white/10 border border-white/20 text-white/50 text-xs font-semibold px-2 py-0.5 rounded-full">
                                        No bookings yet
                                    </span>
                                <% } %>
                            </div>
                            <p class="text-amber-200 text-sm capitalize"><%= home.location %></p>
                            <p class="text-white/60 text-sm">
                                ₹<%= Number(home.pricePerNight).toLocaleString('en-IN') %> / night &nbsp;·&nbsp;
                                Owner: <span class="text-amber-200 font-semibold"><%= home.ownerName || 'Admin' %></span> &nbsp;·&nbsp;
                                ID #<%= home.id %>
                            </p>
                        </div>

                        <!-- Actions -->
                        <div class="flex items-center gap-3 flex-shrink-0">
                            <a href="/listings/<%= home.id %>"
                                class="bg-white/10 border border-white/20 hover:bg-white/20 text-white/70 font-semibold py-2 px-4 rounded-xl text-sm transition"
                                title="Preview this listing">
                                👁
                            </a>
                            <a href="/host/edit-home/<%= home.id %>"
                                class="bg-amber-500/20 border border-amber-400/30 hover:bg-amber-500/40 text-amber-200 font-semibold py-2 px-4 rounded-xl text-sm transition">
                                ✏️ Edit
                            </a>
                            <form action="/host/delete-home/<%= home.id %>" method="POST"
                                onsubmit="return confirm('Delete \'<%= home.housename %>\'? This cannot be undone.')">
                                <button type="submit"
                                    class="bg-red-500/20 border border-red-400/30 hover:bg-red-500/40 text-red-300 font-semibold py-2 px-4 rounded-xl text-sm transition">
                                    🗑️ Delete
                                </button>
                            </form>
                        </div>

                    </div>
                <% }) %>
            </div>
        <% } %>

    </main>

</body>
</html>
