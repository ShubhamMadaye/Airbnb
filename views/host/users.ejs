<%- include('../partials/head') %>
</head>

<body class="bg-gradient-to-br from-amber-600 to-amber-800 text-white font-sans min-h-screen flex flex-col"
    style="font-family: 'Inter', sans-serif;">

    <%- include('../partials/nav') %>

    <main class="flex-1 w-full max-w-5xl mx-auto px-6 py-12">

        <header class="mb-8">
            <h1 class="text-3xl font-bold">👥 Manage Users</h1>
            <p class="text-amber-200 mt-1 text-sm">Admin command center — view registered accounts and toggle ban statuses.</p>
        </header>

        <% if (users.length === 0) { %>
            <div class="bg-white/10 border border-white/10 rounded-2xl p-12 text-center">
                <div class="text-6xl mb-4">👥</div>
                <h2 class="text-xl font-semibold">No registered users</h2>
                <p class="text-amber-200 text-sm mt-2">There are currently no registered users in the database.</p>
            </div>
        <% } else { %>
            <div class="overflow-x-auto rounded-2xl shadow-xl border border-white/10">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="bg-white/20 text-amber-200 uppercase tracking-widest text-xs">
                            <th class="px-5 py-4 text-left">User Details</th>
                            <th class="px-5 py-4 text-left">Role</th>
                            <th class="px-5 py-4 text-center">Host Privileges</th>
                            <th class="px-5 py-4 text-center">Account Status</th>
                            <th class="px-5 py-4 text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% users.forEach((u, i) => { %>
                            <tr class="<%= i % 2 === 0 ? 'bg-white/5' : 'bg-white/10' %> hover:bg-white/20 transition">
                                <td class="px-5 py-4">
                                    <div class="font-semibold text-base"><%= u.name %></div>
                                    <div class="text-white/60 text-xs"><%= u.email %></div>
                                    <div class="text-white/40 text-[10px] mt-0.5">ID: <%= u.id %></div>
                                </td>
                                <td class="px-5 py-4">
                                    <% if (u.role === 'admin') { %>
                                        <span class="bg-red-500/20 text-red-300 border border-red-500/30 text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider">
                                            Admin
                                        </span>
                                    <% } else { %>
                                        <span class="bg-blue-500/20 text-blue-300 border border-blue-500/30 text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider">
                                            User
                                        </span>
                                    <% } %>
                                </td>
                                <td class="px-5 py-4 text-center">
                                    <% if (u.isHost) { %>
                                        <span class="bg-emerald-500/20 text-emerald-300 border border-emerald-500/30 text-xs font-semibold px-2.5 py-1 rounded-full">
                                            🏡 Active Host
                                        </span>
                                    <% } else { %>
                                        <span class="text-white/30 text-xs">—</span>
                                    <% } %>
                                </td>
                                <td class="px-5 py-4 text-center">
                                    <% if (u.isBanned) { %>
                                        <span class="bg-red-600/30 text-red-200 border border-red-500/50 text-xs font-bold px-3 py-1.5 rounded-full inline-flex items-center gap-1 shadow-inner animate-pulse">
                                            🚫 Banned
                                        </span>
                                    <% } else { %>
                                        <span class="bg-green-500/20 text-green-300 border border-green-500/30 text-xs font-semibold px-3 py-1.5 rounded-full">
                                            ✓ Active
                                        </span>
                                    <% } %>
                                </td>
                                <td class="px-5 py-4 text-center">
                                    <% if (u.role !== 'admin') { %>
                                        <% if (u.isBanned) { %>
                                            <form action="/host/unban-user/<%= u.id %>" method="POST" onsubmit="return confirm('Are you sure you want to unban <%= u.name %>?');">
                                                <button type="submit" class="bg-green-500 hover:bg-green-600 text-white text-xs font-bold py-2 px-4 rounded-full transition shadow-md hover:scale-105 transform">
                                                    Unban User
                                                </button>
                                            </form>
                                        <% } else { %>
                                            <form action="/host/ban-user/<%= u.id %>" method="POST" onsubmit="return confirm('WARNING: Are you sure you want to ban <%= u.name %>? They will be immediately blocked from logging in.');">
                                                <button type="submit" class="bg-red-500 hover:bg-red-600 text-white text-xs font-bold py-2 px-4 rounded-full transition shadow-md hover:scale-105 transform">
                                                    Ban User
                                                </button>
                                            </form>
                                        <% } %>
                                    <% } else { %>
                                        <span class="text-white/30 text-xs font-semibold">Protected</span>
                                    <% } %>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } %>

    </main>

</body>
</html>
