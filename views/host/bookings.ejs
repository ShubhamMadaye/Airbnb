<%- include('../partials/head') %>
</head>

<body class="bg-gradient-to-br from-amber-600 to-amber-800 text-white font-sans min-h-screen flex flex-col"
    style="font-family: 'Inter', sans-serif;">

    <%- include('../partials/nav') %>

    <main class="flex-1 w-full max-w-5xl mx-auto px-6 py-12">

        <header class="mb-8">
            <h1 class="text-3xl font-bold">📋 All Bookings</h1>
            <p class="text-amber-200 mt-1 text-sm">Admin view — all customer reservations</p>
        </header>

        <% if (bookings.length === 0) { %>
            <div class="bg-white/10 border border-white/10 rounded-2xl p-12 text-center">
                <div class="text-6xl mb-4">📭</div>
                <h2 class="text-xl font-semibold">No bookings yet</h2>
                <p class="text-amber-200 text-sm mt-2">No customers have made any reservations.</p>
            </div>
        <% } else { %>
            <div class="overflow-x-auto rounded-2xl shadow-xl border border-white/10">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="bg-white/20 text-amber-200 uppercase tracking-widest text-xs">
                            <th class="px-5 py-4 text-left">Home</th>
                            <th class="px-5 py-4 text-left">Customer</th>
                            <th class="px-5 py-4 text-left">Check-in</th>
                            <th class="px-5 py-4 text-left">Check-out</th>
                            <th class="px-5 py-4 text-left">Nights</th>
                            <th class="px-5 py-4 text-right">Total</th>
                            <th class="px-5 py-4 text-center">Status</th>
                            <th class="px-5 py-4 text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% bookings.forEach((booking, i) => { %>
                            <% const isCancelled = booking.status === 'cancelled'; %>
                            <tr class="<%= i % 2 === 0 ? 'bg-white/5' : 'bg-white/10' %> hover:bg-white/20 transition <%= isCancelled ? 'opacity-60' : '' %>">
                                <td class="px-5 py-4 font-semibold capitalize <%= isCancelled ? 'line-through decoration-red-500' : '' %>">
                                    <%= booking.homeName %>
                                    <div class="text-white/40 font-normal text-xs capitalize"><%= booking.homeLocation %></div>
                                </td>
                                <td class="px-5 py-4 <%= isCancelled ? 'line-through decoration-red-500' : '' %>">
                                    <%= booking.userName %>
                                    <div class="text-white/40 text-xs"><%= booking.userEmail %></div>
                                </td>
                                <td class="px-5 py-4 <%= isCancelled ? 'line-through decoration-red-500' : '' %>"><%= new Date(booking.checkIn).toDateString() %></td>
                                <td class="px-5 py-4 <%= isCancelled ? 'line-through decoration-red-500' : '' %>"><%= new Date(booking.checkOut).toDateString() %></td>
                                <td class="px-5 py-4"><%= booking.nights %></td>
                                <td class="px-5 py-4 text-right font-bold text-green-300">₹<%= Number(booking.totalCost).toLocaleString('en-IN') %></td>
                                <td class="px-5 py-4 text-center">
                                    <% if (isCancelled) { %>
                                        <span class="bg-red-500/20 text-red-300 border border-red-500/30 text-xs px-2.5 py-1 rounded-full font-semibold">Cancelled</span>
                                    <% } else { %>
                                        <span class="bg-green-500/20 text-green-300 border border-green-500/30 text-xs px-2.5 py-1 rounded-full font-semibold">Active</span>
                                    <% } %>
                                </td>
                                <td class="px-5 py-4 text-center">
                                    <% if (!isCancelled) { %>
                                        <form action="/host/cancel-booking/<%= booking.id %>" method="POST" onsubmit="return confirm('Are you sure you want to cancel this booking?');">
                                            <button type="submit" class="bg-red-500/80 hover:bg-red-600 text-white text-xs font-semibold py-1.5 px-3 rounded-full transition">
                                                Cancel
                                            </button>
                                        </form>
                                    <% } else { %>
                                        <span class="text-white/30 text-xs">-</span>
                                    <% } %>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                    <tfoot>
                        <tr class="bg-white/20 font-bold">
                            <td colspan="5" class="px-5 py-4 text-amber-200 uppercase tracking-widest text-xs">Total Revenue (Active Only)</td>
                            <td class="px-5 py-4 text-right text-green-300 text-base" colspan="3">
                                ₹<%= bookings.filter(b => b.status !== 'cancelled').reduce((sum, b) => sum + Number(b.totalCost), 0).toLocaleString('en-IN') %>
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        <% } %>

    </main>

</body>
</html>
