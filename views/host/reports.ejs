<%- include('../partials/head') %>
</head>

<body class="bg-gradient-to-br from-amber-600 to-amber-800 text-white font-sans min-h-screen flex flex-col"
    style="font-family: 'Inter', sans-serif;">

    <%- include('../partials/nav') %>

    <main class="flex-1 w-full max-w-5xl mx-auto px-6 py-12">

        <header class="mb-8">
            <h1 class="text-3xl font-bold">🚩 User Reports</h1>
            <p class="text-amber-200 mt-1 text-sm">Review issues reported by users regarding property listings and mark them resolved.</p>
        </header>

        <% if (reports.length === 0) { %>
            <div class="bg-white/10 border border-white/10 rounded-2xl p-12 text-center">
                <div class="text-6xl mb-4">🛡️</div>
                <h2 class="text-xl font-semibold">No reports submitted</h2>
                <p class="text-amber-200 text-sm mt-2">All listings are in good standing. No user reports have been filed.</p>
            </div>
        <% } else { %>
            <div class="overflow-x-auto rounded-2xl shadow-xl border border-white/10">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="bg-white/20 text-amber-200 uppercase tracking-widest text-xs">
                            <th class="px-5 py-4 text-left">Listing Details</th>
                            <th class="px-5 py-4 text-left">Reporter</th>
                            <th class="px-5 py-4 text-left">Reason & Issue Details</th>
                            <th class="px-5 py-4 text-center">Status</th>
                            <th class="px-5 py-4 text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% reports.forEach((r, i) => { %>
                            <% const isOpen = r.status === 'open'; %>
                            <tr class="<%= i % 2 === 0 ? 'bg-white/5' : 'bg-white/10' %> hover:bg-white/20 transition <%= !isOpen ? 'opacity-60' : '' %>">
                                <td class="px-5 py-4 font-semibold capitalize">
                                    <%= r.homeName %>
                                    <div class="text-white/40 font-normal text-xs">Home ID: #<%= r.homeId + 1 %></div>
                                    <div class="mt-2">
                                        <a href="/listings/<%= r.homeId %>" class="bg-amber-500/20 hover:bg-amber-500/40 text-amber-200 border border-amber-400/20 text-[10px] font-bold py-1 px-2.5 rounded-full transition inline-block">
                                            View Listing
                                        </a>
                                    </div>
                                </td>
                                <td class="px-5 py-4">
                                    <div class="font-semibold"><%= r.userName %></div>
                                    <div class="text-white/40 text-xs">User ID: <%= r.userId %></div>
                                    <div class="text-white/40 text-[10px] mt-1"><%= new Date(r.createdAt).toLocaleString() %></div>
                                </td>
                                <td class="px-5 py-4 max-w-xs">
                                    <span class="inline-block bg-red-500/20 border border-red-500/30 text-red-300 text-xs font-bold px-2 py-0.5 rounded mb-1">
                                        <%= r.reason %>
                                    </span>
                                    <p class="text-white/80 text-xs leading-relaxed"><%= r.details || 'No additional details provided.' %></p>
                                </td>
                                <td class="px-5 py-4 text-center">
                                    <% if (isOpen) { %>
                                        <span class="bg-red-500/20 text-red-300 border border-red-500/30 text-xs px-2.5 py-1 rounded-full font-bold uppercase tracking-wider animate-pulse">
                                            Open
                                        </span>
                                    <% } else { %>
                                        <span class="bg-white/10 text-white/50 border border-white/10 text-xs px-2.5 py-1 rounded-full font-semibold uppercase tracking-wider">
                                            Resolved
                                        </span>
                                    <% } %>
                                </td>
                                <td class="px-5 py-4 text-center">
                                    <% if (isOpen) { %>
                                        <form action="/host/resolve-report/<%= r.id %>" method="POST" onsubmit="return confirm('Mark this report as resolved?');">
                                            <button type="submit" class="bg-green-500 hover:bg-green-600 text-white text-xs font-bold py-1.5 px-4 rounded-full transition shadow-md hover:scale-105 transform">
                                                Resolve
                                            </button>
                                        </form>
                                    <% } else { %>
                                        <span class="text-white/30 text-xs">✓ Done</span>
                                    <% } %>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } %>

    </main>

</body>
</html>
